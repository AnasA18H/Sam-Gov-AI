# Domain / TLS (Caddy)
DOMAIN=your-domain.com
ACME_EMAIL=you@example.com

# Postgres
POSTGRES_USER=samgov_user
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
POSTGRES_DB=samgov_db

# App Secrets
SECRET_KEY=CHANGE_ME_LONG_RANDOM
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM

# URLs / CORS
FRONTEND_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com

# Email (optional, required for email verification / notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/auth/signin/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://your-domain.com/api/v1/auth/signin/microsoft/callback

# LLM keys (optional but required for analysis features)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
TAVILY_API_KEY=

# Google Document AI (optional OCR)
# If you use this, copy the service account JSON to the droplet and set an absolute container path.
# Example: GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/gcp_sa.json (recommended via Docker secrets)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_PROJECT_ID=
GOOGLE_PROCESSOR_ID=
GOOGLE_LOCATION=us
GOOGLE_DOCAI_ENABLED=True
