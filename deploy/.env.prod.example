# Core app
APP_NAME=Sam Gov AI
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# Domain / TLS
DOMAIN=GovOpsAi.com
TLS_EMAIL=admin@GovOpsAi.com
FRONTEND_URL=https://www.GovOpsAi.com
CORS_ORIGINS=https://www.GovOpsAi.com

# Secrets (Add these manually in DigitalOcean App Settings)
SECRET_KEY=replace_me_with_64_plus_random_chars
JWT_SECRET_KEY=replace_me_with_64_plus_random_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Managed PostgreSQL (DigitalOcean) - require sslmode=require
# DigitalOcean will provide this automatically via DATABASE_URL if linked
DATABASE_URL=postgresql://dbuser:dbpassword@db-postgresql-nyc3-xxxxx-do-user-xxxxx-0.b.db.ondigitalocean.com:25060/samgov_db?sslmode=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Managed Redis (DigitalOcean)
# DigitalOcean will provide this automatically via REDIS_URL if linked
REDIS_URL=rediss://default:password@xxxxx.b.db.ondigitalocean.com:25061
REDIS_CELERY_URL=rediss://default:password@xxxxx.b.db.ondigitalocean.com:25061

# Storage (DigitalOcean Spaces via S3 API)
STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=YOUR_SPACES_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SPACES_SECRET_KEY
AWS_REGION=sfo3
S3_BUCKET_NAME=samgov-docs
AWS_S3_ENDPOINT_URL=https://sfo3.digitaloceanspaces.com
# Optional CDN/public base. Keep empty for private bucket + presigned URLs.
AWS_S3_PUBLIC_BASE_URL=

# OAuth / integrations
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://www.GovOpsAi.com/api/v1/auth/google/callback

MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=YOUR_MICROSOFT_CLIENT_SECRET
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://www.GovOpsAi.com/api/v1/auth/microsoft/callback

# LLM / search APIs
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=12
TAVILY_INCLUDE_ANSWER=True
TAVILY_MAX_QUERIES_PER_CLIN=8
TAVILY_INCLUDE_DOMAINS=
TAVILY_TIME_RANGE=
TAVILY_REUSE_BY_PRODUCT=True
TAVILY_PARALLEL_MAX_WORKERS=4

# Google Document AI
# In production, it is recommended to paste the raw JSON content into a secret variable
# named GOOGLE_SERVICE_ACCOUNT_JSON and the code will handle it.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_PROJECT_ID=YOUR_GOOGLE_PROJECT_ID
GOOGLE_PROCESSOR_ID=YOUR_GOOGLE_PROCESSOR_ID
GOOGLE_LOCATION=us
GOOGLE_DOCAI_ENABLED=True

# Email / monitoring
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL
SMTP_PASSWORD=YOUR_APP_PASSWORD
SENTRY_DSN=
