APP_NAME="Sam Gov AI"
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1
DOMAIN=GovOpsAi.com
TLS_EMAIL=admin@GovOpsAi.com
FRONTEND_URL=https://www.GovOpsAi.com
CORS_ORIGINS=https://www.GovOpsAi.com

# Secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database & Redis
DATABASE_URL="${db.DATABASE_URL}"
REDIS_URL="${redis-db.REDIS_URL}"
REDIS_CELERY_URL="${redis-db.REDIS_URL}"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Object Storage (DigitalOcean Spaces)
STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=your-spaces-access-key
AWS_SECRET_ACCESS_KEY=your-spaces-secret-key
AWS_REGION=sfo3
S3_BUCKET_NAME=samgov-docs
AWS_S3_ENDPOINT_URL=https://sfo3.digitaloceanspaces.com
AWS_S3_PUBLIC_BASE_URL=""

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://www.GovOpsAi.com/api/v1/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://www.GovOpsAi.com/api/v1/auth/microsoft/callback

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your-gemini-api-key
TAVILY_API_KEY=tvly-...

# Search Settings
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=12
TAVILY_INCLUDE_ANSWER=True
TAVILY_MAX_QUERIES_PER_CLIN=8
TAVILY_INCLUDE_DOMAINS=""
TAVILY_TIME_RANGE=""
TAVILY_REUSE_BY_PRODUCT=True
TAVILY_PARALLEL_MAX_WORKERS=4

# Google Document AI
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_PROCESSOR_ID=your-processor-id
GOOGLE_LOCATION=us
GOOGLE_DOCAI_ENABLED=True

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD="your-app-password"

# Monitoring
SENTRY_DSN="https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX"
